-<http://data.bgs.ac.uk/id/Lexicon/NamedRockUnit/SKLM> <http://data.bgs.ac.uk/ref/Lexicon/hasThicknessDescription> "Up to 3.5m."@en .
-<http://data.bgs.ac.uk/id/Lexicon/NamedRockUnit/SNO> <http://data.bgs.ac.uk/ref/Lexicon/hasThicknessDescription> "0 to c.2m"@en .
-<http://data.bgs.ac.uk/id/Lexicon/NamedRockUnit/SOARV> <http://data.bgs.ac.uk/ref/Lexicon/hasThicknessDescription> "0 to c.10m"@en .
-<http://data.bgs.ac.uk/id/Lexicon/NamedRockUnit/SOYSG> <http://data.bgs.ac.uk/ref/Lexicon/hasThicknessDescription> "0 to c.6m"@en .
-<http://data.bgs.ac.uk/id/Lexicon/NamedRockUnit/SPHT> <http://data.bgs.ac.uk/ref/Lexicon/hasThicknessDescription> "Up to 7m"@en .
